#!/bin/sh
set -e

case "$1" in
    purge)
        if getent passwd etcd > /dev/null 2>&1; then
            deluser --quiet --system etcd || true
        fi

        if getent group etcd > /dev/null 2>&1; then
            delgroup --quiet --system etcd || true
        fi

        rm -rf /var/lib/etcd
        rm -rf /var/log/etcd
        rm -rf /etc/etcd
        ;;
esac

#DEBHELPER#

exit 0
