#!/usr/bin/make -f

%:
	dh $@

override_dh_installsystemd:
	dh_installsystemd --package=go2rtc --name=go2rtc --no-enable --no-start

override_dh_auto_configure:
	@true

override_dh_auto_build:
	@true

override_dh_auto_test:
	@true

override_dh_dwz:
	@true

override_dh_strip:
	@true

override_dh_auto_install:
	install -D -m 755 binaries/go2rtc \
		$(CURDIR)/debian/go2rtc/usr/bin/go2rtc

	install -D -m 640 debian/go2rtc.yaml \
		$(CURDIR)/debian/go2rtc/etc/go2rtc/go2rtc.yaml

	install -d -m 750 $(CURDIR)/debian/go2rtc/var/lib/go2rtc

override_dh_installdeb:
	dh_installdeb
	echo /etc/go2rtc/go2rtc.yaml >> $(CURDIR)/debian/go2rtc/DEBIAN/conffiles
