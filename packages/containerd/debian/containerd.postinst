#!/bin/sh
set -e

case "$1" in
    configure)
        mkdir -p /var/lib/containerd
        chmod 0710 /var/lib/containerd

        mkdir -p /etc/containerd
        chmod 0755 /etc/containerd

        if [ ! -f /etc/containerd/config.toml ]; then
            containerd config default > /etc/containerd/config.toml
        fi
        ;;
esac

#DEBHELPER#

exit 0
